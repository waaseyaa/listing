{
    "name": "waaseyaa/listing",
    "description": "Views-equivalent declarative listing pipeline for Waaseyaa entities.",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {
            "type": "path",
            "url": "../foundation"
        },
        {
            "type": "path",
            "url": "../entity"
        },
        {
            "type": "path",
            "url": "../entity-storage"
        },
        {
            "type": "path",
            "url": "../field"
        },
        {
            "type": "path",
            "url": "../cache"
        },
        {
            "type": "path",
            "url": "../access"
        },
        {
            "type": "path",
            "url": "../typed-data"
        }
    ],
    "require": {
        "php": ">=8.5",
        "waaseyaa/access": "^0.1.0-alpha.227",
        "waaseyaa/cache": "^0.1.0-alpha.227",
        "waaseyaa/entity": "^0.1.0-alpha.227",
        "waaseyaa/entity-storage": "^0.1.0-alpha.227",
        "waaseyaa/field": "^0.1.0-alpha.227",
        "waaseyaa/foundation": "^0.1.0-alpha.227",
        "waaseyaa/typed-data": "^0.1.0-alpha.227"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\Listing\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\Listing\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "waaseyaa": {
            "layer": 3,
            "providers": [
                "Waaseyaa\\Listing\\ServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "0.1.x-dev",
            "dev-develop/v1.1": "0.1.x-dev"
        }
    },
    "config": {
        "sort-packages": true
    }
}
